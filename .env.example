# ============================================================================
# builders.review — environment variables (MySQL + Prisma + Auth.js)
# Copy to .env.local. NEVER commit real secrets.
# ============================================================================

# --- Database (MySQL 8+) ----------------------------------------------------
# Create an EMPTY database first (see docs/MYSQL-SETUP.md); Prisma builds the
# tables. URL-encode special characters in the password (@ -> %40, etc.).
DATABASE_URL="mysql://USERNAME:PASSWORD@HOST:3306/builders_review"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# Generate a strong secret:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Public base URL of the app. In production set to your real https:// origin.
AUTH_URL="http://localhost:3000"
# Local-only escape hatch: "true" opens /admin WITHOUT auth for previewing the
# dashboard. NEVER set this in production. Leave blank/false everywhere real.
AUTH_PREVIEW_ADMIN="false"

# --- Magic-link email (SMTP) ------------------------------------------------
# Any SMTP provider works (Resend, Postmark, SES, Mailgun, Gmail app password).
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="builders.review <no-reply@builders.review>"

# --- Public site ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# "false" = ONLY real approved reviews from MySQL (REQUIRED in production).
# "true"  = clearly-marked development sample reviews (never writes to MySQL).
NEXT_PUBLIC_USE_SAMPLE_DATA="false"

# ----------------------------------------------------------------------------
# GOOGLE REVIEWS (the only source with a real API connector implemented)
# Needs BOTH a Places API key AND a real Place ID; otherwise Google stays
# disabled and no Google rating is displayed.
# ----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=""
GOOGLE_PLACE_ID=""
GOOGLE_MAPS_PROFILE_URL=""

# --- Scheduled sync endpoint (/api/cron/sync) -------------------------------
SYNC_CRON_SECRET=""

# --- Rate limiting ----------------------------------------------------------
REVIEW_RATE_LIMIT_PER_HOUR="3"

# --- Search Console / Bing verification (optional) --------------------------
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_BING_SITE_VERIFICATION=""

# --- Cookieless analytics (optional) ----------------------------------------
NEXT_PUBLIC_ANALYTICS_DOMAIN=""

# ----------------------------------------------------------------------------
# OPTIONAL attachment storage (metadata is in MySQL; files go to a provider).
# Leave blank to keep attachment uploads disabled.
# ----------------------------------------------------------------------------
# STORAGE_PROVIDER=""          # e.g. "s3" | "cloudinary" | "vercel-blob"
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# ----------------------------------------------------------------------------
# NOT YET IMPLEMENTED — no connector exists until you obtain permitted access.
# ----------------------------------------------------------------------------
TRUSTPILOT_API_KEY=""
FACEBOOK_PAGE_ACCESS_TOKEN=""
GLASSDOOR_PARTNER_ID=""
GLASSDOOR_PARTNER_KEY=""
